{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/MessengerProfile",
  "title": "MessengerProfile",
  "type": "object",
  "description": "Messenger profile settings.",
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "greeting": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "locale": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                }
              }
            }
          },
          "get_started": {
            "type": "object",
            "properties": {
              "payload": {
                "type": "string"
              }
            }
          },
          "persistent_menu": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    }
  }
}