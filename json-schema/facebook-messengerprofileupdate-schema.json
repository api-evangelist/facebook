{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/MessengerProfileUpdate",
  "title": "MessengerProfileUpdate",
  "type": "object",
  "description": "Update for Messenger profile settings.",
  "properties": {
    "greeting": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "locale": {
            "type": "string",
            "example": "default"
          },
          "text": {
            "type": "string",
            "example": "Welcome to our page!"
          }
        }
      }
    },
    "get_started": {
      "type": "object",
      "properties": {
        "payload": {
          "type": "string",
          "example": "GET_STARTED"
        }
      }
    }
  }
}