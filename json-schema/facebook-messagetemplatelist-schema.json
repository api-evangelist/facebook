{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/MessageTemplateList",
  "title": "MessageTemplateList",
  "type": "object",
  "description": "Paginated list of message templates.",
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/MessageTemplate"
      }
    },
    "paging": {
      "type": "object",
      "properties": {
        "cursors": {
          "type": "object",
          "properties": {
            "before": {
              "type": "string"
            },
            "after": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}